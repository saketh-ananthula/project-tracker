# PostgreSQL (Railway provides DATABASE_URL when you add the Postgres plugin)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Required in production (generate a long random string)
JWT_SECRET="change-me-to-a-long-random-secret"

# Optional: allowed browser origin for CORS (e.g. your Railway app URL)
# CLIENT_ORIGIN="https://your-app.up.railway.app"

PORT=3000
